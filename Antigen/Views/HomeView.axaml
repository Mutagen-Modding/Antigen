<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:plugins="clr-namespace:Mutagen.Bethesda.Plugins;assembly=Mutagen.Bethesda.Kernel"
             xmlns:viewModels="clr-namespace:Antigen.ViewModels.Singleton"
             mc:Ignorable="d"
             d:DesignWidth="600"
             d:DesignHeight="400"
             x:Class="Antigen.Views.HomeView"
             x:DataType="viewModels:HomeVM"
             x:Name="Root">
    <Border CornerRadius="8"
            Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}">
        <Grid RowDefinitions="40,*">
            <Grid Grid.Row="0"
                  x:Name="Bar"
                  ColumnDefinitions="*,Auto"
                  Margin="4">
                <TextBox Grid.Column="0"
                         VerticalAlignment="Center"
                         Text="{Binding SearchText, Delay=150}"
                         PlaceholderText="Filter mods..." />

                <!-- Close Button -->
                <Button Grid.Column="1"
                        Content="✕"
                        Command="{Binding CloseCommand}"
                        Background="Transparent"
                        Padding="11,7"
                        BorderThickness="0"
                        FontWeight="Bold"
                        ToolTip.Tip="Close">
                    <Button.Styles>
                        <Style Selector="Button:pointerover /template/ ContentPresenter">
                            <Setter Property="Background"
                                    Value="IndianRed" />
                        </Style>
                    </Button.Styles>
                </Button>
            </Grid>

            <!-- Mod List -->
            <ScrollViewer Grid.Row="1"
                          Margin="8,0,8,8"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding FilteredModKeys}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="plugins:ModKey">
                            <Button Content="{Binding FileName}"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Left"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="8,6"
                                    Command="{Binding #Root.ViewModel.StartWatchingCommand}"
                                    CommandParameter="{Binding}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
